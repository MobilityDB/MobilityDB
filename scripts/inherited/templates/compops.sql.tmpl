/**
 * @file
 * @brief Ever/always and temporal comparison functions and operators for
 * {BRIEF}
 */

/*****************************************************************************
 * Ever/Always Comparison Functions
 *****************************************************************************/

CREATE FUNCTION ever_eq({BASE}, {TEMP})
  RETURNS boolean
  AS 'MODULE_PATHNAME', 'Ever_eq_{BASE}_{TEMP}'
  SUPPORT tspatial_supportfn
  LANGUAGE C IMMUTABLE STRICT PARALLEL SAFE;
CREATE FUNCTION always_eq({BASE}, {TEMP})
  RETURNS boolean
  AS 'MODULE_PATHNAME', 'Always_eq_{BASE}_{TEMP}'
  SUPPORT tspatial_supportfn
  LANGUAGE C IMMUTABLE STRICT PARALLEL SAFE;

CREATE OPERATOR ?= (
  LEFTARG = {BASE}, RIGHTARG = {TEMP},
  PROCEDURE = ever_eq,
  NEGATOR = %<>,
  RESTRICT = tspatial_sel, JOIN = tspatial_joinsel
);
CREATE OPERATOR %= (
  LEFTARG = {BASE}, RIGHTARG = {TEMP},
  PROCEDURE = always_eq,
  NEGATOR = ?<>,
  RESTRICT = tspatial_sel, JOIN = tspatial_joinsel
);

CREATE FUNCTION ever_ne({BASE}, {TEMP})
  RETURNS boolean
  AS 'MODULE_PATHNAME', 'Ever_ne_{BASE}_{TEMP}'
  LANGUAGE C IMMUTABLE STRICT PARALLEL SAFE;
CREATE FUNCTION always_ne({BASE}, {TEMP})
  RETURNS boolean
  AS 'MODULE_PATHNAME', 'Always_ne_{BASE}_{TEMP}'
  LANGUAGE C IMMUTABLE STRICT PARALLEL SAFE;

CREATE OPERATOR ?<> (
  LEFTARG = {BASE}, RIGHTARG = {TEMP},
  PROCEDURE = ever_ne,
  NEGATOR = %=,
  RESTRICT = tspatial_sel, JOIN = tspatial_joinsel
);
CREATE OPERATOR %<> (
  LEFTARG = {BASE}, RIGHTARG = {TEMP},
  PROCEDURE = always_ne,
  NEGATOR = ?=,
  RESTRICT = tspatial_sel, JOIN = tspatial_joinsel
);

