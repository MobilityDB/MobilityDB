/*****************************************************************************
 * Temporal spatial relationships
 *
 * Each function returns a tbool whose value at instant t is the static
 * spatial relation applied to the cell boundary at t. Composition is
 * the same as the ever/always above: cast the cell boundary to
 * tgeometry and delegate to tgeometry's temporal spatial-rel kernel.
 *****************************************************************************/

CREATE FUNCTION tContains(geometry, {TEMP})
  RETURNS tbool
  LANGUAGE SQL IMMUTABLE STRICT PARALLEL SAFE
  AS $$ SELECT tContains($1, {BASE}_cell_to_boundary($2)::tgeometry) $$;
CREATE FUNCTION tContains({TEMP}, geometry)
  RETURNS tbool
  LANGUAGE SQL IMMUTABLE STRICT PARALLEL SAFE
  AS $$ SELECT tContains({BASE}_cell_to_boundary($1)::tgeometry, $2) $$;
CREATE FUNCTION tContains({TEMP}, {TEMP})
  RETURNS tbool
  LANGUAGE SQL IMMUTABLE STRICT PARALLEL SAFE
  AS $$ SELECT tContains({BASE}_cell_to_boundary($1)::tgeometry,
                          {BASE}_cell_to_boundary($2)::tgeometry) $$;

