SELECT (sp).point, asText((sp).tcbuffer) FROM
  (SELECT spaceSplit(tcbuffer '[Cbuffer(Point(1 1),0.5)@2000-01-01, Cbuffer(Point(5 5),0.5)@2000-01-05]', 2.0) AS sp) t
  ORDER BY 1;
                   point                    |                                                     astext                                                     
--------------------------------------------+----------------------------------------------------------------------------------------------------------------
 010100000000000000000000000000000000000000 | {[Cbuffer(POINT(1 1),0.5)@Sat Jan 01 00:00:00 2000 PST, Cbuffer(POINT(2 2),0.5)@Sun Jan 02 00:00:00 2000 PST)}
 010100000000000000000000400000000000000040 | {[Cbuffer(POINT(2 2),0.5)@Sun Jan 02 00:00:00 2000 PST, Cbuffer(POINT(4 4),0.5)@Tue Jan 04 00:00:00 2000 PST)}
 010100000000000000000010400000000000001040 | {[Cbuffer(POINT(4 4),0.5)@Tue Jan 04 00:00:00 2000 PST, Cbuffer(POINT(5 5),0.5)@Wed Jan 05 00:00:00 2000 PST]}
(3 rows)

SELECT (sp).point, (sp).time, asText((sp).tcbuffer) FROM
  (SELECT spaceTimeSplit(tcbuffer '[Cbuffer(Point(1 1),0.5)@2000-01-01, Cbuffer(Point(5 5),0.5)@2000-01-05]', 2.0, interval '2 days') AS sp) t
  ORDER BY 2, 1;
