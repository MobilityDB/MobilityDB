WITH test AS (
  SELECT temp |=| tnpoint '[Npoint(1, 0.2)@2001-06-01, Npoint(1, 0.5)@2001-07-01]' AS distance
  FROM tbl_tnpoint ORDER BY 1 LIMIT 3 )
SELECT round(distance, 6) FROM test;
  round   
