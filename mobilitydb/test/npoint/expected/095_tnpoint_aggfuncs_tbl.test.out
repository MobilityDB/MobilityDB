(1 row)

WITH temp(inst) AS (
  SELECT tnpoint(Npoint(1, abs(extract(epoch from d) / 1.0e9)), d)
  FROM generate_series(timestamptz '1970-01-01', '2000-01-10', interval '1 day') AS d )
SELECT numInstants(appendInstant(inst ORDER BY inst)) FROM temp;
 numinstants 
-------------
           2
(1 row)

