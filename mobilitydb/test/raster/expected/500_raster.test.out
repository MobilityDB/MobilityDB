SELECT array_length(
  trajectory_quadbins(
    tgeompointFromText('SRID=4326;{Point(-60.0 45.0)@2024-01-01 00:00:00+00, Point(0.0 45.0)@2024-01-02 00:00:00+00, Point(60.0 45.0)@2024-01-03 00:00:00+00}'),
    3
  ), 1
) AS num_distinct_tiles;
