/* Errors */
-- Invalid JSON.
SELECT poseFromGeoPose('not-json');
ERROR:  Invalid GeoPose JSON: null expected (at offset 1)
SELECT poseFromGeoPose('{"quaternion":{"x":0,"y":0,"z":0,"w":1}}');
ERROR:  GeoPose JSON missing required 'position' object
SELECT poseFromGeoPose('{"position":{"h":0},"quaternion":{"x":0,"y":0,"z":0,"w":1}}');
ERROR:  GeoPose 'position' must carry numeric 'lat' and 'lon' members
SELECT poseFromGeoPose('{"position":{"lat":0,"lon":0,"h":0}}');
ERROR:  GeoPose JSON requires either a 'quaternion' object (Basic-Quaternion) or an 'angles' object (Basic-YPR)
SELECT poseFromGeoPose('{"position":{"lat":0,"lon":0,"h":0},"quaternion":{"x":0,"y":0,"z":0}}');
ERROR:  GeoPose 'quaternion' must carry numeric 'w','x','y','z' members
SELECT asGeoPose(pose 'Pose(Point(1 1),0.5)', 99, 6);
ERROR:  Unknown GeoPose conformance class 99 (0 = Basic-Quaternion, 1 = Basic-YPR)
SELECT asGeoPose(pose 'SRID=5676;Pose(Point(1 1),0.5)', 0, 6);
ERROR:  GeoPose JSON requires SRID 4326 (WGS-84), got 5676
SELECT asGeoPose(tpose 'Pose(Point(8 47), 0)@2026-01-01', 0, 6);
                                                                                                                asgeopose                                                                                                                
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 {"type":"TemporalGeoPose","version":"1.0","conformance":"Basic-Quaternion","interpolation":"None","instants":[{"position":{"lat":47,"lon":8,"h":0},"quaternion":{"x":0,"y":0,"z":0,"w":1},"validTime":"Thu Jan 01 00:00:00 2026 PST"}]}
(1 row)

SELECT asText(tposeFromGeoPose(asGeoPose(tpose 'Pose(Point(8 47), 0)@2026-01-01', 0, 6)));
                           astext                           
------------------------------------------------------------
 Pose(POINT Z (8 47 0),1,0,0,0@Thu Jan 01 00:00:00 2026 PST
(1 row)

