UPDATE test_trgeometry3d_posops
SET kdtree_idx = ( SELECT COUNT(*) FROM tbl_trgeometry3d t1, tbl_trgeometry3d t2 WHERE t1.temp &<# t2.temp )
WHERE op = '&<#' and leftarg = 'trgeometry3d' and rightarg = 'trgeometry3d';
UPDATE 1
UPDATE test_trgeometry3d_posops
SET kdtree_idx = ( SELECT COUNT(*) FROM tbl_trgeometry3d t1, tbl_trgeometry3d t2 WHERE t1.temp #&> t2.temp )
WHERE op = '#&>' and leftarg = 'trgeometry3d' and rightarg = 'trgeometry3d';
UPDATE 1
DROP INDEX tbl_trgeometry3d_kdtree_idx;
