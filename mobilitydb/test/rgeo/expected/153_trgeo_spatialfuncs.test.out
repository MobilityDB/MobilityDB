SELECT asText(atGeometry(
  trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));Pose(Point(2 0), 0.0)@2001-01-01',
  geometry 'Polygon((1 -1,3 -1,3 1,1 1,1 -1))'));
                                     astext                                     
--------------------------------------------------------------------------------
