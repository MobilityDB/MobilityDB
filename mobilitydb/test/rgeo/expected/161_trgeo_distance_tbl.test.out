SELECT round(MAX(maxValue(t1.temp <-> setSRID(t2.temp, 5676))), 6)
FROM tbl_trgeometry2d t1, tbl_tgeompoint t2
WHERE t1.temp <-> setSRID(t2.temp, 5676) IS NOT NULL;
