SELECT extent(temp) FROM (VALUES
  (NULL::trgeometry),
  (trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));Pose(Point(0 0), 0.0)@2001-01-01'),
  (NULL::trgeometry)) t(temp);
                                        extent                                        
--------------------------------------------------------------------------------------
 STBOX XT(((0,0),(1,1)),[Mon Jan 01 00:00:00 2001 PST, Mon Jan 01 00:00:00 2001 PST])
(1 row)

SELECT extent(temp) FROM (VALUES
