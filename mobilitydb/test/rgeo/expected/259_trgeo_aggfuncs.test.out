SELECT tcount(temp) FROM (VALUES
  (NULL::trgeometry),
  (trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));Pose(Point(0 0), 0.0)@2001-01-01'),
  (NULL::trgeometry)) t(temp);
              tcount              
----------------------------------
 {1@Mon Jan 01 00:00:00 2001 PST}
(1 row)

SELECT tcount(temp) FROM (VALUES
  (trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));[Pose(Point(0 0),0.0)@2001-01-01, Pose(Point(1 0),0.0)@2001-01-02]'),
  (trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));[Pose(Point(2 0),0.0)@2001-01-03, Pose(Point(3 0),0.0)@2001-01-04]')) t(temp);
                                                                tcount                                                                
--------------------------------------------------------------------------------------------------------------------------------------
 {[1@Mon Jan 01 00:00:00 2001 PST, 1@Tue Jan 02 00:00:00 2001 PST], [1@Wed Jan 03 00:00:00 2001 PST, 1@Thu Jan 04 00:00:00 2001 PST]}
(1 row)

