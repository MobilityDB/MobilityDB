SELECT asText(minTimeDeltaSimplify(
  trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));[Pose(Point(0 0),0.0)@2001-01-01,
    Pose(Point(1 0),0.0)@2001-01-01 06:00:00, Pose(Point(2 0),0.0)@2001-01-02,
    Pose(Point(3 0),0.0)@2001-01-03]',
  interval '12 hours'));
                                                                                       astext                                                                                       
------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 POLYGON((0 0,1 0,1 1,0 1,0 0));{Pose(POINT(0 0),0)@Mon Jan 01 00:00:00 2001 PST, Pose(POINT(2 0),0)@Tue Jan 02 00:00:00 2001 PST, Pose(POINT(3 0),0)@Wed Jan 03 00:00:00 2001 PST}
(1 row)

SELECT asText(minDistSimplify(
  trgeometry 'Polygon((0 0,1 0,1 1,0 1,0 0));[Pose(Point(0 0),0.0)@2001-01-01,
    Pose(Point(0.1 0),0.0)@2001-01-02, Pose(Point(5 0),0.0)@2001-01-03,
    Pose(Point(10 0),0.0)@2001-01-04]',
  2.0));
                                                                                       astext                                                                                        
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 POLYGON((0 0,1 0,1 1,0 1,0 0));{Pose(POINT(0 0),0)@Mon Jan 01 00:00:00 2001 PST, Pose(POINT(5 0),0)@Wed Jan 03 00:00:00 2001 PST, Pose(POINT(10 0),0)@Thu Jan 04 00:00:00 2001 PST}
(1 row)

