%%
%% This style is derived from the manual
%% http://dblatex.sourceforge.net/doc/manual/sec-custom-latex.html
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texstyle}[2017/04/25 PostGIS DocBook Style]

%% Just use the original package and pass the options
\RequirePackageWithOptions{docbook}

%% Use T1 encoding + Latin Modern fonts so apostrophes inside \texttt
%% (which is what DocBook <varname> renders to) stay upright instead of
%% ligaturing into U+201D ("right double quotation mark").  The default
%% Computer Modern fonts have an `'' → "` ligature in monospace; Latin
%% Modern Typewriter at T1 has proper straight-quote glyphs.
%% This fixes patterns like `endian text=''` inside <varname> rendering
%% as `endian text="` in the PDF.
\usepackage[T1]{fontenc}
\usepackage{lmodern}

%% Make regular quotes within programlisting tags (#3726)
\usepackage{listings}
\lstset{upquote=true}
\usepackage{upquote}
